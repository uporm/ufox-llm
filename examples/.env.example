# Required for all examples
UFOX_LLM_PROVIDER=compatible
UFOX_LLM_API_KEY=sk-xxx

# Required when UFOX_LLM_PROVIDER=compatible
UFOX_LLM_BASE_URL=https://api.deepseek.com/v1

# Optional model override
UFOX_LLM_MODEL=deepseek-chat

# Optional for multimodal example (choose one)
# UFOX_LLM_IMAGE_FILE=/absolute/path/to/your/image.png
# UFOX_LLM_IMAGE_URL=https://example.com/image.png
